{
  "name": "gonr-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:auth-smoke": "vitest run __tests__/auth-routes.test.ts",
    "check": "npm run typecheck && npm run lint && npm test && npm run build",
    "env:check": "node scripts/check-env.mjs",
    "infra:check": "node scripts/check-env.mjs && node scripts/check-backend-infra.mjs && bash scripts/check-migrations.sh",
    "audit:pro-voice": "node scripts/audit-pro-voice.mjs",
    "audit:pro-voice:strict": "node scripts/audit-pro-voice.mjs --strict",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
