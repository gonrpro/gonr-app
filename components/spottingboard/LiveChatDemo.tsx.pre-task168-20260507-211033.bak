'use client'

// components/spottingboard/LiveChatDemo.tsx — TASK-168 v2
//
// Animated live demo on spottingboard.com landing. Bilingual EN/ES.
// Conversation, governance card, header strip, and structured-card-preview
// label all swap when the EN/ES pill toggles. Animation resets to step 0 on
// language change so visitors don't see a half-translated bubble mid-cycle.

import { useEffect, useMemo, useState } from 'react'
import { useLanguage } from '@/lib/i18n/LanguageContext'

// ──────────────────────────────────────────────────────────────────────────────
// Conversation content (EN + ES)
// ──────────────────────────────────────────────────────────────────────────────

type BubbleSide = 'operator' | 'spottingboard'

interface Bubble {
  id: string
  side: BubbleSide
  text: string
}

interface DemoCopy {
  conversation: Bubble[]
  card: {
    title: string
    body: string
    badges: { label: string; tone: 'blue' | 'purple' | 'mute' }[]
  }
  header: {
    title: string
    plant: string
    livePill: string
  }
  cardEyebrow: string
  ariaTyping: string
}

// Demo content focuses on stain removal (the spotter's actual work), not
// intake/routing. Generic — any spotter at any plant should recognize the
// flow immediately. Tight bubbles, plant-neutral framing, no Jerry's
// references.
const COPY_EN: DemoCopy = {
  conversation: [
    {
      id: 'q',
      side: 'spottingboard',
      text: 'Red wine on cotton — what’s your first move at the spotting board?',
    },
    {
      id: 'a',
      side: 'operator',
      text: 'Cool flush from the back. Tannin formula, work it in with a bone. POG if it’s set. No heat until the pigment’s clear.',
    },
    {
      id: 'confirm',
      side: 'spottingboard',
      text: 'Captured: red wine on cotton → cool flush, tannin formula, POG if set, no heat. Adding to the ops book draft.',
    },
  ],
  card: {
    title: 'Red wine on cotton',
    body: 'Cool flush from the back. Tannin formula with a bone. POG if set. No heat until pigment is clear.',
    badges: [
      { label: 'tannin', tone: 'blue' },
      { label: 'no-heat-first', tone: 'purple' },
      { label: 'unreviewed', tone: 'mute' },
    ],
  },
  header: {
    title: 'Guided capture',
    plant: 'Spotter rule · plant-local',
    livePill: 'Live example',
  },
  cardEyebrow: 'Structured card preview',
  ariaTyping: 'typing',
}

const COPY_ES: DemoCopy = {
  conversation: [
    {
      id: 'q',
      side: 'spottingboard',
      text: 'Vino tinto sobre algodón — ¿cuál es tu primer movimiento en el manchador?',
    },
    {
      id: 'a',
      side: 'operator',
      text: 'Enjuague frío desde atrás. Fórmula tanino, trabajar con espátula. POG si está fijada. Sin calor hasta que el pigmento esté limpio.',
    },
    {
      id: 'confirm',
      side: 'spottingboard',
      text: 'Capturado: vino tinto sobre algodón → enjuague frío, fórmula tanino, POG si está fijada, sin calor. Lo agrego al borrador del libro de operaciones.',
    },
  ],
  card: {
    title: 'Vino tinto sobre algodón',
    body: 'Enjuague frío desde atrás. Fórmula tanino con espátula. POG si está fijada. Sin calor hasta que el pigmento esté limpio.',
    badges: [
      { label: 'tanino', tone: 'blue' },
      { label: 'sin calor primero', tone: 'purple' },
      { label: 'sin revisar', tone: 'mute' },
    ],
  },
  header: {
    title: 'Captura guiada',
    plant: 'Regla del manchador · local de planta',
    livePill: 'Ejemplo en vivo',
  },
  cardEyebrow: 'Vista previa de tarjeta estructurada',
  ariaTyping: 'escribiendo',
}

// ──────────────────────────────────────────────────────────────────────────────
// Timing
// ──────────────────────────────────────────────────────────────────────────────

const TIMING = {
  initialDelay: 600,
  typingIndicator: 900,
  bubbleHold: 1800,
  cardHold: 4500,
  loopGap: 1200,
}

type Step =
  | 'initial'
  | 'typing-q'
  | 'show-q'
  | 'typing-a'
  | 'show-a'
  | 'typing-confirm'
  | 'show-confirm'
  | 'show-card'
  | 'pause'

const STEP_ORDER: Step[] = [
  'initial',
  'typing-q',
  'show-q',
  'typing-a',
  'show-a',
  'typing-confirm',
  'show-confirm',
  'show-card',
  'pause',
]

function durationFor(step: Step): number {
  switch (step) {
    case 'initial': return TIMING.initialDelay
    case 'typing-q':
    case 'typing-a':
    case 'typing-confirm':
      return TIMING.typingIndicator
    case 'show-q':
    case 'show-a':
    case 'show-confirm':
      return TIMING.bubbleHold
    case 'show-card': return TIMING.cardHold
    case 'pause': return TIMING.loopGap
  }
}

function visibleBubbleIds(step: Step): Set<string> {
  switch (step) {
    case 'initial':
    case 'typing-q':
      return new Set()
    case 'show-q':
    case 'typing-a':
      return new Set(['q'])
    case 'show-a':
    case 'typing-confirm':
      return new Set(['q', 'a'])
    case 'show-confirm':
    case 'show-card':
    case 'pause':
      return new Set(['q', 'a', 'confirm'])
  }
}

function typingIndicatorSide(step: Step): BubbleSide | null {
  if (step === 'typing-q' || step === 'typing-confirm') return 'spottingboard'
  if (step === 'typing-a') return 'operator'
  return null
}

function cardVisible(step: Step): boolean {
  return step === 'show-card' || step === 'pause'
}

function useReducedMotion(): boolean {
  const [reduced, setReduced] = useState(false)
  useEffect(() => {
    if (typeof window === 'undefined' || !window.matchMedia) return
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)')
    setReduced(mq.matches)
    const handler = (e: MediaQueryListEvent) => setReduced(e.matches)
    mq.addEventListener?.('change', handler)
    return () => mq.removeEventListener?.('change', handler)
  }, [])
  return reduced
}

// ──────────────────────────────────────────────────────────────────────────────
// Component
// ──────────────────────────────────────────────────────────────────────────────

export function LiveChatDemo() {
  const reducedMotion = useReducedMotion()
  const { lang } = useLanguage()
  const copy = useMemo<DemoCopy>(() => (lang === 'es' ? COPY_ES : COPY_EN), [lang])
  const [stepIndex, setStepIndex] = useState(0)
  const step = STEP_ORDER[stepIndex] ?? 'initial'

  // When language flips mid-cycle, restart the demo so visitors see a clean
  // ES (or EN) reveal from step 0 instead of a half-translated bubble.
  useEffect(() => {
    setStepIndex(0)
  }, [lang])

  useEffect(() => {
    if (reducedMotion) {
      setStepIndex(STEP_ORDER.indexOf('show-card'))
      return
    }
    const timer = setTimeout(() => {
      setStepIndex((prev) => (prev + 1) % STEP_ORDER.length)
    }, durationFor(step))
    return () => clearTimeout(timer)
  }, [stepIndex, step, reducedMotion])

  const visibleIds = visibleBubbleIds(step)
  const showingTyping = typingIndicatorSide(step)
  const showCard = cardVisible(step)

  return (
    <div
      className="relative rounded-3xl border border-white/8 bg-[#0e0e11]/92 p-4 sm:p-5 backdrop-blur-md"
      style={{
        boxShadow:
          '0 24px 80px -30px rgba(0,212,170,0.22), 0 0 0 1px rgba(255,255,255,0.04), inset 0 1px 0 rgba(255,255,255,0.04)',
      }}
    >
      {/* Subtle turquoise top edge for the "cooler" accent */}
      <div
        aria-hidden="true"
        className="pointer-events-none absolute inset-x-6 top-0 h-px"
        style={{
          background: 'linear-gradient(90deg, transparent, rgba(0,212,170,0.55), transparent)',
        }}
      />

      <div className="mb-4 flex items-center justify-between border-b border-white/8 pb-3">
        <div>
          <div className="text-sm font-extrabold text-white">{copy.header.title}</div>
          <div className="text-xs text-white/45">{copy.header.plant}</div>
        </div>
        <div className="rounded-full border border-[#00d4aa]/40 bg-[#00d4aa]/10 px-2.5 py-1 text-[10px] font-black uppercase tracking-[0.14em] text-[#00d4aa]">
          {copy.header.livePill}
        </div>
      </div>

      <div className="space-y-3" style={{ minHeight: '13rem' }} aria-live="polite">
        {copy.conversation.map((b) => (
          <ChatBubble
            key={b.id}
            side={b.side}
            text={b.text}
            visible={visibleIds.has(b.id)}
          />
        ))}
        {showingTyping && (
          <TypingIndicator side={showingTyping} ariaLabel={copy.ariaTyping} key={`typing-${step}`} />
        )}
      </div>

      <GovernanceCard visible={showCard} eyebrow={copy.cardEyebrow} card={copy.card} />
    </div>
  )
}

// ──────────────────────────────────────────────────────────────────────────────
// Sub-components
// ──────────────────────────────────────────────────────────────────────────────

function ChatBubble({
  side,
  text,
  visible,
}: {
  side: BubbleSide
  text: string
  visible: boolean
}) {
  const isOperator = side === 'operator'
  return (
    <div
      className={`flex ${isOperator ? 'justify-end' : 'justify-start'}`}
      style={{
        opacity: visible ? 1 : 0,
        transform: visible ? 'translateY(0)' : 'translateY(8px)',
        transition: 'opacity 320ms cubic-bezier(0.22, 0.61, 0.36, 1), transform 320ms cubic-bezier(0.22, 0.61, 0.36, 1)',
      }}
      aria-hidden={!visible}
    >
      <div
        className={`max-w-[86%] rounded-2xl px-4 py-3 text-sm leading-6 ${
          isOperator
            ? 'bg-[#00d4aa] text-[#061018] font-semibold'
            : 'border border-[#1f2a3d] bg-[#161e2e] text-[#dbe4ef]'
        }`}
      >
        {text}
      </div>
    </div>
  )
}

function TypingIndicator({ side, ariaLabel }: { side: BubbleSide; ariaLabel: string }) {
  const isOperator = side === 'operator'
  return (
    <div
      className={`flex ${isOperator ? 'justify-end' : 'justify-start'}`}
      aria-label={ariaLabel}
      role="status"
    >
      <div
        className={`max-w-[86%] rounded-2xl px-4 py-3 ${
          isOperator
            ? 'bg-[#00d4aa]/20 border border-[#00d4aa]/40'
            : 'border border-[#1f2a3d] bg-[#161e2e]'
        }`}
        style={{ display: 'inline-flex', alignItems: 'center', gap: '4px' }}
      >
        <Dot delay={0} color={isOperator ? '#00d4aa' : '#94a3b8'} />
        <Dot delay={150} color={isOperator ? '#00d4aa' : '#94a3b8'} />
        <Dot delay={300} color={isOperator ? '#00d4aa' : '#94a3b8'} />
      </div>
    </div>
  )
}

function Dot({ delay, color }: { delay: number; color: string }) {
  return (
    <span
      style={{
        display: 'inline-block',
        width: '6px',
        height: '6px',
        borderRadius: '50%',
        background: color,
        animation: `sb-dot-pulse 1100ms ${delay}ms ease-in-out infinite`,
      }}
    />
  )
}

function GovernanceCard({
  visible,
  eyebrow,
  card,
}: {
  visible: boolean
  eyebrow: string
  card: DemoCopy['card']
}) {
  return (
    <div
      className="mt-5 rounded-2xl border border-[#1f2a3d] bg-[#0a0e1a] p-4"
      style={{
        opacity: visible ? 1 : 0,
        transform: visible ? 'translateY(0)' : 'translateY(10px)',
        transition: 'opacity 380ms cubic-bezier(0.22, 0.61, 0.36, 1), transform 380ms cubic-bezier(0.22, 0.61, 0.36, 1)',
        pointerEvents: visible ? 'auto' : 'none',
      }}
      aria-hidden={!visible}
    >
      <div className="mb-3 text-xs font-black uppercase tracking-[0.14em] text-[#64748b]">
        {eyebrow}
      </div>
      <div className="text-sm font-bold text-white">{card.title}</div>
      <p className="mt-2 text-sm leading-6 text-[#94a3b8]">{card.body}</p>
      <div className="mt-4 flex flex-wrap gap-2 text-[11px] font-bold">
        {card.badges.map((b) => (
          <span
            key={b.label}
            className={`rounded-md px-2 py-1 ${
              b.tone === 'blue'
                ? 'border border-[#5b9eff]/50 text-[#5b9eff]'
                : b.tone === 'purple'
                  ? 'border border-[#a78bfa]/50 text-[#a78bfa]'
                  : 'border border-[#64748b]/60 text-[#94a3b8]'
            }`}
          >
            {b.label}
          </span>
        ))}
      </div>

      <style>{`
        @keyframes sb-dot-pulse {
          0%, 80%, 100% { opacity: 0.3; transform: translateY(0); }
          40% { opacity: 1; transform: translateY(-2px); }
        }
        @media (prefers-reduced-motion: reduce) {
          @keyframes sb-dot-pulse {
            0%, 100% { opacity: 0.7; transform: none; }
          }
        }
      `}</style>
    </div>
  )
}
